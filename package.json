{
  "name": "svn-merge-tool",
  "version": "2.0.0",
  "description": "Customizable SVN merge and conflict resolution tool",
  "main": "dist/index.js",
  "bin": {
    "svnmerge": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/cli.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "test:unit": "vitest run test/unit",
    "test:integration": "vitest run test/integration",
    "test:e2e": "vitest run test/e2e"
  },
  "keywords": [
    "svn",
    "merge",
    "conflict",
    "resolution"
  ],
  "author": "alanwalk",
  "license": "MIT",
  "dependencies": {
    "chalk": "^4.1.2",
    "commander": "^12.0.0",
    "minimatch": "^9.0.3",
    "ora": "^5.4.1",
    "yaml": "^2.4.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@vitest/coverage-v8": "^1.6.1",
    "@vitest/ui": "^1.6.1",
    "typescript": "^5.3.0",
    "vitest": "^1.6.1"
  }
}
